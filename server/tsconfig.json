{
  "$schema": "https://www.schemastore.org/tsconfig",
  "include": ["src/**/*", "scripts/*", "package.json", "./env.d.ts", "*.config.ts"],
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "types": ["bun-types", "node"],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.app.tsbuildinfo",

    "paths": {
      "~/*": ["./*"],
      "#apps/*": ["./src/apps/*"],
      "#context": ["./src/context.ts"],
      "#context/*": ["./src/context/*"],
      "#db": ["./src/db/index.ts"],
      "#db/*": ["./src/db/*"],
      "#env/*": ["./src/env/*"],
      "#modules/*": ["./src/modules/*"],
      "#redis": ["./src/redis/index.ts"],
      "#redis/*": ["./src/redis/*"],
      "#server": ["./src/index.ts"],
      "#utils": ["./src/utils/index.ts"],
      "#utils/*": ["./src/utils/*"],
      "#packages/schema/*": ["../packages/schema/src/*"],
      "#queues": ["./src/queues/index.ts"]
    }
  }
}
