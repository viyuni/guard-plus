<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>新订单通知</title>
</head>
<body style="margin:0;background:#f6f7f9;color:#1f2937;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
  <div style="max-width:640px;margin:0 auto;padding:32px 20px;">
    <div style="background:#ffffff;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">
      <div style="padding:24px 28px;border-bottom:1px solid #e5e7eb;">
        <div style="font-size:14px;color:#6b7280;">新订单通知</div>
        <h1 style="margin:8px 0 0;font-size:22px;line-height:1.35;color:#111827;"><%= productName %> 已创建订单</h1>
      </div>

      <div style="padding:24px 28px;">
        <table style="width:100%;border-collapse:collapse;font-size:14px;line-height:1.6;">
          <tr>
            <td style="width:120px;padding:8px 0;color:#6b7280;">商品</td>
            <td style="padding:8px 0;color:#111827;"><%= productName %></td>
          </tr>
          <tr>
            <td style="width:120px;padding:8px 0;color:#6b7280;">用户</td>
            <td style="padding:8px 0;color:#111827;"><%= username %></td>
          </tr>
          <tr>
            <td style="width:120px;padding:8px 0;color:#6b7280;">B站 UID</td>
            <td style="padding:8px 0;color:#111827;"><%= biliUid %></td>
          </tr>
          <tr>
            <td style="width:120px;padding:8px 0;color:#6b7280;">消耗积分</td>
            <td style="padding:8px 0;color:#111827;"><%= price %> <%= pointTypeName %></td>
          </tr>
          <tr>
            <td style="width:120px;padding:8px 0;color:#6b7280;">配送方式</td>
            <td style="padding:8px 0;color:#111827;"><%= deliveryType %></td>
          </tr>
          <tr>
            <td style="width:120px;padding:8px 0;color:#6b7280;">订单状态</td>
            <td style="padding:8px 0;color:#111827;"><%= status %></td>
          </tr>
          <tr>
            <td style="width:120px;padding:8px 0;color:#6b7280;">创建时间</td>
            <td style="padding:8px 0;color:#111827;"><%= createdAt %></td>
          </tr>
        </table>

        <div style="margin-top:20px;padding:14px 16px;background:#f9fafb;border:1px solid #eef0f3;border-radius:6px;">
          <div style="font-size:13px;color:#6b7280;margin-bottom:6px;">用户备注</div>
          <div style="font-size:14px;color:#111827;white-space:pre-wrap;"><%= userRemark %></div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
