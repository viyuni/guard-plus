# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=guard-plus

# Runtime
NODE_ENV=production
# Comma-separated allowed browser origins.
ADMIN_ORIGINS=https://admin.example.com
USER_ORIGINS=https://example.com,https://shop.example.com

# Published ports on the host
GUARD_PLUS_POSTGRES_PUBLISHED_PORT=39699
GUARD_PLUS_REDIS_PUBLISHED_PORT=39679
GUARD_PLUS_ADMIN_PUBLISHED_PORT=39960
GUARD_PLUS_USER_PUBLISHED_PORT=39980

# App secrets
# DATA_SECRET is shared globally for encrypted data. Keep the same value across all services.
DATA_SECRET=change-me-generate-a-long-random-secret
ADMIN_JWT_SECRET=change-me-generate-a-long-random-secret
USER_JWT_SECRET=change-me-generate-a-long-random-secret

# Bilibili live room
BILI_ROOM=32706521
BILI_REGISTER_CODE_TTL_SECONDS=300

# Redis client
REDIS_CONNECTION_TIMEOUT_MS=5000
REDIS_IDLE_TIMEOUT_MS=0
REDIS_MAX_RETRIES=100

# Logging
LOG_LEVEL=info

# Initial super admin account
SUPER_ADMIN_UID=0721
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=change-me

# Viyuni login sync for event ingestion
VIYUNI_LOGIN_SYNC_URL=https://username:accessToken@example.com
VIYUNI_LOGIN_SYNC_PASSWORD=change-me

# SMTP for user email flows
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=notifications@example.com
SMTP_PASS=change-me
SMTP_FROM=Guard Plus <notifications@example.com>
NOTIFY_EMAILS=ops@example.com,admin@example.com
